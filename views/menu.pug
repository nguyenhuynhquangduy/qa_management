extends ./layout
block head
    link(rel='stylesheet', href='/css/index.css')
    link(rel="stylesheet" href='/css/jquery-ui.css')
    script(src="/js/bootstrap.bundle.min.js")
    script(src="/js/bootstrap.min.js")
    script(src='/js/jquery-3.6.0.min.js')
    script(src='/js/jquery-ui.min.js')
    style.
        html, body {
            height: 100%;
            overflow: auto;
        }
   
        .well {
            min-height: 20px;
            padding: 19px;
            margin-bottom: 20px;
            background-color: #f5f5f5;
            border: 1px solid #e3e3e3;
            border-radius: 4px;
            -webkit-box-shadow: inset 0 1px 1px rgba(0, 0, 0, .05);
            box-shadow: inset 0 1px 1px rgba(0, 0, 0, .05);
        }
        .target {
            //- font-weight: bold;
            //- letter-spacing: 2px;
            text: uppercase;
            min-height: 20px;
            color:rgb(239, 242, 245);
            padding: 49px  0px 49px 0px;
            //- margin-bottom: 20px;
            background-color:rgba(227, 157, 66, 1);
        }
        dialog:not([open]) {
            display: none;
        }
        #dialogInfoStore {
        padding: 10px;
        margin: 10px auto;
        border: 1px solid #b6e3dfff;
        border-radius: 15px;
        position: fixed;
        top: 10%;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1050;
        background: white;
        padding: 1rem;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.3);

        }
        .hidden {
            display: none;
        }
block content   
    .container-fluid        
        .section
            h1.text-center.text-uppercase(style='color:rgb(216, 89, 16)') WELCOME
        .section 
            .container
                .row.well.text-uppercase
                    .col-md-3
                        button.btn.w-100.btn-default.target#target1 VIÊN CỐM BỘT
                    .col-md-3
                        button.btn.w-100.btn-default.target#target2 NULL
                    .col-md-3
                        button.btn.w-100.btn-default.target#target3 NULL
                    .col-md-3
                        button.btn.w-100.btn-default.target#target4 DANH MỤC
                    
            
                .row.well.hidden
                    .col-md-3.d-grid
                        button.btn.d-grid.btn-default.target#target5 NULL
                    .col-md-3.d-grid
                        button.btn.d-grid.btn-default.target#target6 NULL
                    .col-md-3.d-grid
                        button.btn.d-grid.btn-default.target#target7 NULL         
                    .col-md-3.d-grid    
                        button.btn.d-grid.btn-default.target#target8 
                
            br
            br
            br
            br
            br
            br
            br
            br
            br               
        .section 
            .container
                dialog#dialogInfoStore 
                    form(method="POST" action="/updateInfoStore")
                        .text-right
                            button.button.btn.btn-danger.btn-sm.close-btn.close-update-info(type="button") ×
                        .form-row
                            .col-md-12
                                label(for="storeName") TEST
                                input.form-control(type="text" name="name" id="storeName" )     
                            
                            .col-md-12.mt-2
                                button.btn.btn-block.btn-primary.text-uppercase SAVE
            
    script.
        $(document).ready(function() {
            $('#target1').click(function() {
                window.location.href = '/sanxuat/menu-viencom'
            })
            $('#target4').click(function() {
                window.location.href = '/danhmuc/danhmuc-menu'
            })
            $('#target3').click(function() {
                window.location.href = '/customers/customerManager'
            })
            $('#target5').click(function() {
                window.location.href = '/services/serviceManager'
            })
            $('#target6').click(function() {
                window.location.href = '/colors/colorManager'
            })
            $('#target9').click(function() {
                window.location.href = '/services/complete'
            })
            $('#target9-bulk').click(function() {
                window.location.href = '/services/complete-bulk'
            })
        })
