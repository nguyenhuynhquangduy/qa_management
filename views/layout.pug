doctype html
html(lang="vi")
    head
        //metadata
        meta(charset='utf-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        meta(name='description' content='Dự án QA MANAGEMENT - ND SOFT')
        meta(name='author' content='Nguyen Huynh Quang Duy')
        //title
        title= title + ' ND SOFT'
        //stylesheet
        link(rel="stylesheet" href="/css/bootstrap.min.css")
        //- link(rel='stylesheet', href='/css/main.css')
        link(rel='stylesheet' href='/css/style.css')
        link(rel='stylesheet' href='/css/all.min.css')
        //favicon
        link(rel='shortcut icon' href='/image/ndsoft.ico')
        script(src="/js/jquery.min.js")
        script(src="/js/bootstrap.bundle.min.js")
        style. 
            body {
                background: #f8f9fa;
            }
            .card {
                transition: transform 0.2s, box-shadow 0.2s;
            }
            .card:hover {
                //- transform: translateY(-5px) scale(1.03);
                box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            }
            .navbar-brand {
                font-weight: bold;
                letter-spacing: 2px;
            }
            .nav .btn {
                border: solid 1px #000009922 !important;
                border-radius: 5px !important;
                color: #00009922;
                text-align: center;
                text-decoration: none;
                display: inline-block;
                font-size: 16px;
                margin: 4px 2px;
                //- cursor: pointer;
            }                  
            .nav-item.dropdown {
                position: relative;
                }
            .dropdown-content {
                display: none;
                position: absolute;
                background: #fff;
                background-color: rgb(18, 114, 98);
                min-width: 120px;
                box-shadow: 0 8px 16px rgba(0,0,0,0.2);
                z-index: 9999;
                left: 0;
                top: 100%;
                padding: 0;
                margin: 0;
                border-radius: 4px;
                border: 1px solid rgb(19, 118, 141);
            }
            .dropdown-content li {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .dropdown-content li a {
                display: block;
                padding: 8px 16px;
                color:rgb(22, 120, 53);
                text-decoration: none;
            }
            .dropdown-content li a:hover {
                background:rgb(22, 120, 53);
            }
            h1{
                margin-top: 10px;
                font-size: 32px;
                font-weight: bold;
            }
       
        block head
    body(style='font-family: "Times New Roman", Times, serif; display: flex; flex-direction: column; min-height: 100vh;')
        //header
        header#header
            .medcen
                nav.navbar.navbar-expand-lg.navbar-dark.bg-primary.shadow.mb-1.py-4(style='font-size:21px')
                    .container-fluid
                        if !user
                            a.navbar-brand.px-4(href="/") CÔNG TY CỔ PHẦN MEDCEN
                        else
                            a.navbar-brand.px-4(href="/menu") CÔNG TY CỔ PHẦN MEDCEN
                        button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#mainNav", aria-controls="mainNav", aria-expanded="false", aria-label="Toggle navigation")
                            span.navbar-toggler-icon
                        .collapse.navbar-collapse#mainNav
                            ul.navbar-nav.ms-auto.mb-2.mb-lg-0
                                if user
                                    if user.admin
                                        li.nav-item
                                            a.nav-link(href="/admin") Quản trị
                                    li.nav-item
                                        a.nav-link(href="/menu") Menu
                                    li.nav-item
                                        a.nav-link(href="/users/profile")= user.fullname
                                    li.nav-item
                                        a.nav-link(href="/signout") Sign Out
        block content
        footer#footer.bg-dark.text-white.py-1.mt-auto(style="color: #fff;")
            .container-fluid
                .footer-content(style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;")
                    .left License © 2026 ND SOFT
                    .right nguyenhuynhquangduy@gmail.com Mr.Duy
    script.
        document.addEventListener('DOMContentLoaded', function() {
            var toggles = document.querySelectorAll('.dropdown-toggle');

            toggles.forEach(function(toggle) {
                toggle.addEventListener('click', function(event) {
                    event.preventDefault();
                    
                    // Ẩn tất cả các dropdown khác trước khi hiển thị dropdown hiện tại
                    toggles.forEach(function(otherToggle) {
                        if (otherToggle !== toggle) {
                            otherToggle.nextElementSibling.style.display = 'none';
                        }
                    });

                    // Hiển thị hoặc ẩn dropdown hiện tại
                    var dropdownContent = this.nextElementSibling;
                    dropdownContent.style.display = (dropdownContent.style.display === 'block') ? 'none' : 'block';
                });
            });

            // Ẩn dropdown khi nhấp vào bất cứ đâu ngoài dropdown
            document.addEventListener('click', function(event) {
                if (!event.target.matches('.dropdown-toggle')) {
                    toggles.forEach(function(toggle) {
                        toggle.nextElementSibling.style.display = 'none';
                    });
                }
            });
        })

