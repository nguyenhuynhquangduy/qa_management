                //- Main Table Content (9 columns)
                .col-md-10
                    .card.shadow-sm.p-3
                        #main-content
                            //- Nội dung bảng của bạn ở đây
                            iframe#adminFrame(src="" width="100%" height="550px" frameborder="0")
    script.
        $(document).ready(function() {
            $('#addUser').on('click', function(e) {
                e.preventDefault(); // Chặn thẻ 'a' nhảy trang
                
                // Đặt src của iframe bằng đúng cái Route bạn đã tạo ở Bước 1
                $('#adminFrame').attr('src','/admin/add-user');
            })

            $('#userList').on('click', function(e) {
                e.preventDefault(); // Chặn thẻ 'a' nhảy trang
                
                // Đặt src của iframe bằng đúng cái Route baise tạo ở Bước 1
                $('#adminFrame').attr('src','/admin/user-list');
            })
            $('#rightsManagement').on('click', function(e) {
                e.preventDefault(); // Chặn thẻ 'a' nhảy trang
                
                $('#adminFrame').attr('src','/rights/rights-management');
            })
            $('#rightsGroup').on('click', function(e) {
                e.preventDefault(); // Chặn thẻ 'a' nhảy trang
                
                $('#adminFrame').attr('src','/rights/rights-group');
            })
            $('#rightsActive').on('click', function(e) {
                e.preventDefault(); // Chặn thẻ 'a' nhảy trang
                
                $('#adminFrame').attr('src','/rights/rights-active');
            })
            $('#logsManagement').on('click', function(e) {
                e.preventDefault(); // Chặn thẻ 'a' nhảy trang
                
                $('#adminFrame').attr('src','/admin/logs');
            })
            
        })