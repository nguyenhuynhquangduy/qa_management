                                    href='#logsMenu' 
                                    data-bs-toggle='collapse' 
                                    role='button' 
                                    aria-expanded='false' 
                                    aria-controls='logsMenu'
                                )
                                    span 
                                        i.fas.fa-user-cog.me-2
                                        | Logs Manager
                                    i.fas.fa-chevron-down.small                
                                .collapse#logsMenu(data-menu-id="logs-manager")
                                    .list-group.mt-2
                                        a.list-group-item.list-group-item-action.btn#logsManagement
                                            i.fas.fa-gear.me-2
