        document.addEventListener('DOMContentLoaded', function () {
            // Tìm tất cả các phần tử collapse có ID
            const collapses = document.querySelectorAll('.collapse');

            collapses.forEach(collapseEl => {
                const menuId = collapseEl.getAttribute('data-menu-id');
                const bsCollapse = new bootstrap.Collapse(collapseEl, { toggle: false });

                // 1. Kiểm tra trạng thái cũ trong sessionStorage
                if (sessionStorage.getItem(menuId) === 'open') {
                    bsCollapse.show();
                }

                // 2. Lắng nghe sự kiện khi menu mở ra
                collapseEl.addEventListener('shown.bs.collapse', function () {
                    sessionStorage.setItem(menuId, 'open');
                });

                // 3. Lắng nghe sự kiện khi menu đóng lại
                collapseEl.addEventListener('hidden.bs.collapse', function () {
                    sessionStorage.removeItem(menuId);
                });
            });
        });
block content 
    .container-fluid
        .section.card
            h1.text-center.text-uppercase(style='color:rgb(216, 89, 16)') ADMIN MANAGER
        .section 
            if errorMessages && errorMessages.length
                ul
                    each message in errorMessages
                        li(style="color: red;")= message
            if successMessages && successMessages.length
                ul
                    each message in successMessages
                        li(style="color: green;")= message
        .section.col-md-12 
            //- .row.mb-3
            //-     .col-12
            //-         .card.p-4.shadow-sm
            //-             h1.text-center.text-uppercase.m-0(style='color:rgb(216, 89, 16)') ADMIN MANAGER

            .row
                //- Sidebar Menu (3 columns)
                .col-md-2
                    .card.shadow-sm.p-3
                        ul.list-unstyled
                            li.mb-2
                                //- Button toggle cho User Manager
                                a.btn.btn-primary.w-100.text-start.d-flex.justify-content-between.align-items-center(
                                    href='#userMenu' 
                                    data-bs-toggle='collapse' 
                                    role='button' 
                                    aria-expanded='false' 
                                    aria-controls='userMenu'
                                )
                                    span 
                                        i.fas.fa-user-cog.me-2
                                        | User Manager
                                    i.fas.fa-chevron-down.small
                                
                                //- Nội dung Dropdown (Collapse)
                                .collapse#userMenu(data-menu-id="user-manager")
                                    .list-group.mt-2
                                        a.list-group-item.list-group-item-action.btn#userList
