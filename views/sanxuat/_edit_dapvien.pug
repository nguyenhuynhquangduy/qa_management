.btn.btn-outline-primary.mt-4#btnDapVien(type="button" data-id=sanpham.id) Dập viên/Bao phim/Đóng nang
.section#dapVien.hidden.card        
    form.row.border#formDapVien(method="POST")
        input(type="hidden" name="losanxuatId" value=sanpham.id)
        .col-md-4
            .form-group
                label.font-color(for='khoiLuongYeuCauDap') Khối Lượng Viên (mg) (Yêu cầu )
                input.form-control(type='text' name='KLV_yeucau' id='khoiLuongYeuCauDap')
            .form-group
                label.font-color(for='khoiLuongPKN') Khối Lượng Viên (PKN)
                input.form-control(type='text' name='KLV_PKN' id='khoiLuongPKN')
            .form-group.border.mt-4
                label.font-color Định lượng 
                br
                .div.ms-4
                    each hoatchat in hoatchats
                        label(for=`hoatChat${hoatchat.tenHoatChat}`) #{hoatchat.tenHoatChat}
                        input.form-control(type='number' name=`dapVien_dinhLuong[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` min="0" max="1000" step="0.01" placeholder='ex: 1.01')
            .form-group
                label.font-color(for='dongdeudonvilieu') Đồng đều đồn vị liều
                input.form-control(type='text' name='dongDeuDonViLieu' id='dongdeudonvilieu')
            .form-group
                label.font-color(for='ra') Rã
                input.form-control(type='text' name='ra' id='ra')
        .col-md-4
            label.font-color Hoà tan (S1)
            br
            .div.ms-4
                each hoatchat in hoatchats
                    .form-group.border.mt-1.p-1
                        label.font-color.mb-3(for=`hoatChat${hoatchat.tenHoatChat}`) #{hoatchat.tenHoatChat}
                        .row.font-mini.p-0.text-center
                            .col-md-2
                                label Viên 1
                                input.form-control(type='text' name=`dapVien_hoatan1_vien1[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 2
                                input.form-control(type='text' name=`dapVien_hoatan1_vien2[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 3
                                input.form-control(type='text' name=`dapVien_hoatan1_vien3[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 4
                                input.form-control(type='text' name=`dapVien_hoatan1_vien4[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 5
                                input.form-control(type='text' name=`dapVien_hoatan1_vien5[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 6
                                input.form-control(type='text' name=`dapVien_hoatan1_vien6[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
            label.font-color Hoà tan (S2)
            br
            .div.ms-4
                each hoatchat in hoatchats
                    .form-group.border.mt-1.p-1
                        label.font-color.mb-3(for=`hoatChat${hoatchat.tenHoatChat}`) #{hoatchat.tenHoatChat}
                        .row.font-mini.p-0.text-center
                            .col-md-2
                                label Viên 1
                                input.form-control(type='number' name=`dapVien_hoatan2_vien1[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 2
                                input.form-control(type='number' name=`dapVien_hoatan2_vien2[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 3
                                input.form-control(type='number' name=`dapVien_hoatan2_vien3[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 4
                                input.form-control(type='number' name=`dapVien_hoatan2_vien4[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 5
                                input.form-control(type='number' name=`dapVien_hoatan2_vien5[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
                            .col-md-2
                                label Viên 6
                                input.form-control(type='number' name=`dapVien_hoatan2_vien6[${hoatchat.id}]` id=`hoatChat${hoatchat.tenHoatChat}` )
        .col-md-4        
            .form-group 
                label.font-color(for='doRa') Tạp đơn
                input.form-control(type='text' name='tapDon' id='tapDon')
            .form-group
                label.font-color(for='tapKhac') Tạp khác
                input.form-control(type='text' name='tapKhac' id='tapKhac')
            .form-group
                label.font-color(for='tongTap') Tổng tạp
                input.form-control(type='text' name='tongTap' id='tongTap')
    .btn.btn-primary.mt-4#saveDapVien(type='submit') Lưu            
        
                        

script.
    let isLoadingDapVien = false;
    $('#btnDapVien').on('click', async function() {
        //- $('#dapVien').slideToggle();
        if (isLoadingDapVien) return;
        isLoadingDapVien = true;
    try{
        if($('#dapVien').is(':hidden')){
            const id = $('#btnDapVien').data('id');
            const url = `/sanxuat/api/get-dapvien?id=${id}`;
            const response = await fetch(url);
            const data = await response.json();
       
            if(data){
                // Tự động đổ dữ liệu vào các ô input tương ứng theo thuộc tính name
            Object.keys(data).forEach(key => {
                if (key === 'hoatchats') return; // Bỏ qua mảng hoạt chất để xử lý riêng bên dưới
                const $input = $(`#formDapVien [name="${key}"]`);
                if ($input.length) {
                    $input.val(data[key]);
                }
            })
                        // Đổ dữ liệu mảng hoạt chất (Hòa tan, Định lượng...)
                        if (data.hoatchats && Array.isArray(data.hoatchats)) {
                            data.hoatchats.forEach(hoatchat => {
                                Object.keys(hoatchat).forEach(attrKey => {
                                    const $input = $(`#formDapVien [name="${attrKey}[${hoatchat.id}]"]`);
                                    if ($input.length) {
                                        $input.val(hoatchat[attrKey]);
                                    }
                                });
                            });
                        }
        
        }}
        $('#dapVien').slideToggle();
        }catch(e){
            console.error(e);
        }finally{
        setTimeout(() => {
            isLoadingDapVien = false;
        }, 500);
        }
    })
    // 1. SỬA: Đổi từ const thành let để có thể gán lại giá trị
    let savingDapVien = false; 
    let count = 0;
    let action = 0;
    $('#saveDapVien').on('click', async function(e) {
        e.preventDefault();
        count +=1;
        console.log('count:' ,count)
        // Chống spam click
        if (savingDapVien) return;
        savingDapVien = true;
        
        try {
            const data = {};
            $('#formDapVien').find('input, select, textarea').each(function() {
                const $el = $(this);
                const name = $el.attr('name');
                if (!name) return;
                
                // Xử lý lấy giá trị chuẩn cho từng loại input
                let val;
                if ($el.attr('type') === 'checkbox') {
                    val = $el.is(':checked');
                } else if ($el.attr('type') === 'radio') {
                    // Nếu là radio, chỉ lấy giá trị của thẻ đang được chọn
                    if (!$el.is(':checked')) return;
                    val = $el.val();
                } else {
                    val = $el.val();
                }
                
                    const match = name.match(/^(.+)\[(\d+)\]$/);
                    if (match) {
                        const fieldName = match[1];
                        const hoatChatId = match[2];
                        
                        if (!data[fieldName]) data[fieldName] = {};
                        data[fieldName][hoatChatId] = val;
                    } else {
                        data[name] = val;
                    }
            });
            
            // 2. SỬA: Gộp chung 1 khối try-catch để gửi API
            const response = await fetch('/sanxuat/api/edit-dapvien', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            });
            
            const result = await response.json();
            
            if (response.ok) {
                toast(result.message || 'Lưu thông tin thành công!', '#28a745');
            } else {
                toast(result.message || 'Có lỗi xảy ra khi lưu dữ liệu!', '#dc3545');
            }
            
        } catch (error) {
            console.error('Lỗi khi xử lý hoặc gửi dữ liệu:', error);
            toast('Không thể kết nối đến máy chủ hoặc lỗi xử lý dữ liệu!', '#dc3545');
        } finally {
            // Mở khóa cho phép bấm lại sau 500ms
            setTimeout(() => {
                savingDapVien = false;
            }, 1500);       
        }
    });