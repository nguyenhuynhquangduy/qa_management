    script.
        function initHoatChatAutocomplete($input) {
            //Kiểm tra thư viện autocomplete đã được load chưa
            if (!$.fn.autocomplete) {
                return;
            }
            $input.autocomplete({
                source: function(request, response) {
                    (async () => {
                        try {
                            const res = await fetch(`/danhmuc/api/ten-hoatchat?term=${encodeURIComponent(request.term)}`);
                            const data = await res.json();
                            response(data.map(item => ({ label: item.tenHoatChat, value: item.tenHoatChat })));
                        } catch (e) {
                            console.error('Lỗi khi lấy hoạt chất:', e);
                            response([]);
                        }
                    })();
                },
                minLength: 1,
                //- focus: function(event, ui) {
                //-     event.preventDefault();
                //-     $(this).val(ui.item.value);
                //- },
                select: function(event, ui) {
                    event.preventDefault();
                    $(this).val(ui.item.value);
                }
            });
        }
        //- $('#btnBTPCom').on('click', function() {
        //-     $('#BTPCom').slideToggle();
        //- })
        $('#saveBTPCom').on('click', async function(e) {
            e.preventDefault();
            
            // 1. Thu thập dữ liệu từ các input trong container #formBTPCom
            const data = {};
            // Tạo sẵn object trống cho định lượng để lát nữa nhét ID vào
            data['BTP_dinhLuong'] = {};
            $('#formBTPCom input').each(function() {
                const name = $(this).attr('name');
                if (!name) return;
                //- if (name) {
                //-     // Xử lý lấy giá trị, nếu là checkbox thì lấy true/false, còn lại lấy value
                //-     data[name] = $(this).attr('type') === 'checkbox' ? $(this).is(':checked') : $(this).val();
                //- }
                // Lấy giá trị của input
                const val = $(this).attr('type') === 'checkbox' ? $(this).is(':checked') : $(this).val();
                // KIỂM TRA: Nếu name có dạng BTP_dinhLuong[ID]
                const match = name.match(/^BTP_dinhLuong\[(\d+)\]$/);
                if (match) {
                    const id = match[1]; // Lấy ra ID (ví dụ: 6 hoặc 7)
                    data['BTP_dinhLuong'][id] = val; // Nhét vào object lồng
                } else {
                    // Các trường bình thường khác (losanxuatId, KLV_yeucaudap,...)
                    data[name] = val;
                }
            });
            // Lúc này, object `data` truyền đi sẽ tự động có cấu trúc:
            // { losanxuatId: '5', BTP_dinhLuong: { "6": "98.6", "7": "107" }, ... }
            try {
                // 2. Thực hiện fetch gửi dữ liệu về server
                const response = await fetch('/sanxuat/api/edit-btpcom', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (response.ok) {
                    toast(result.message || 'Lưu thông tin thành công!', '#28a745');
                } else {
                    toast(result.message || 'Có lỗi xảy ra khi lưu dữ liệu!', '#dc3545');
                }
            } catch (error) {
                console.error('Lỗi khi gửi dữ liệu:', error);
            }
        })
        $('#saveThongTinPhaChe').on('click', async function(e) {
            e.preventDefault();
            
            // 1. Thu thập dữ liệu từ các input trong container #formThongTinPhaChe
            const data = {};
            $('#formThongTinPhaChe input').each(function() {
                const name = $(this).attr('name');
                if (name) {
                    // Xử lý lấy giá trị, nếu là checkbox thì lấy true/false, còn lại lấy value
                    data[name] = $(this).attr('type') === 'checkbox' ? $(this).is(':checked') : $(this).val();
                }
            });

            try {
                // 2. Thực hiện fetch gửi dữ liệu về server
                const response = await fetch('/sanxuat/api/edit-thongtinphache', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (response.ok) {
                    toast(result.message || 'Lưu thông tin thành công!', '#28a745');
                } else {
                    toast(result.message || 'Có lỗi xảy ra khi lưu dữ liệu!', '#dc3545');
                }
            } catch (error) {
                console.error('Lỗi fetch:', error);
                toast('Không thể kết nối đến máy chủ!', '#dc3545');
            }
        })

        function addHoatChatInput(value = '') {
            const $item = $(
                `<div class="input-group mb-2 hoat-chat-item">
                    <input type="text" class="form-control findHoatChat" name="tenHoatChat[]" placeholder="Tên hoạt chất" required>
                    <button class="btn btn-outline-danger remove-hoat-chat" type="button">
                        <i class="fas fa-times"></i>
                    </button>
                </div>`
            );
            $item.find('input').val(value || '');
            $('#listHoatChat').append($item);
            initHoatChatAutocomplete($item.find('.findHoatChat'));
        }

        function populateHoatChats(hoatchats) {
            $('#listHoatChat').empty();
            if (Array.isArray(hoatchats) && hoatchats.length > 0) {
                hoatchats.forEach(hc => {
                    addHoatChatInput(hc.tenHoatChat || hc || '');
                });
            } else {
                addHoatChatInput('');
            }
        }

        $(document).ready(function() {
            $('#btnThongTinChung').on('click', function() {
                $('#thongTinChung').slideToggle();
           
            });
            $('#btnThongTinPhaChe').on('click', async function() {
                const id = $(this).data('id');
                
                // Nếu section đang ẩn và chuẩn bị mở ra, hãy load dữ liệu cũ (nếu có)
                if ($('#thongTinPhaChe').is(':hidden')) {
                    try {
                        const res = await fetch(`/sanxuat/api/get-thongtinphache?id=${id}`);
                        const oldData = await res.json();
                        
                        if (oldData) {
                            // Tự động đổ dữ liệu vào các ô input tương ứng theo thuộc tính name
                            Object.keys(oldData).forEach(key => {
                                const $input = $(`#formThongTinPhaChe [name="${key}"]`);
                                if ($input.length) {
                                    if ($input.attr('type') === 'date' && oldData[key]) {
                                        // Format lại ngày yyyy-MM-dd để input date hiểu được
                                        $input.val(oldData[key].split('T')[0]);
                                    } else {
                                        $input.val(oldData[key]);
                                    }
                                }
                            });
                        }
                    } catch (e) {
                        console.error("Không thể tải thông tin pha chế cũ:", e);
                    }
                }

                $('#thongTinPhaChe').slideToggle();
            });

            $('#btnBTPCom').on('click', async function() {
                const id = $(this).data('id');
                
                // Nếu section đang ẩn và chuẩn bị mở ra, hãy load dữ liệu cũ (nếu có)
                if ($('#BTPCom').is(':hidden')) {
                    try {
                        const res = await fetch(`/sanxuat/api/get-btpcom?id=${id}`);
                        const btpcomData = await res.json();
                        
                        if (btpcomData) {
                            // Tự động đổ dữ liệu vào các ô input tương ứng theo thuộc tính name
                            Object.keys(btpcomData).forEach(key => {
                                if (key === 'hoatchats') return; // Bỏ qua mảng hoạt chất để xử lý riêng bên dưới
                                const $input = $(`#formBTPCom [name="${key}"]`);
                                if ($input.length) {
                                    $input.val(btpcomData[key]);
                                }
                            });

                            // Populate hoatchats BTP_dinhLuong
                            if (btpcomData.hoatchats && Array.isArray(btpcomData.hoatchats)) {
                                btpcomData.hoatchats.forEach(hoatchat => {
                                    const $hoatChatInput = $(`#formBTPCom input[name="BTP_dinhLuong[${hoatchat.id}]"]`);
                                    if ($hoatChatInput.length) {
                                        $hoatChatInput.val(hoatchat.BTP_dinhLuong);
                                    }
                                });
                            }
                        }
                    } catch (e) {
                        console.error("Không thể tải thông tin BTP - Cốm cũ:", e);
                    }
                }
                $('#BTPCom').slideToggle();
            });
            // Nhận dữ liệu hoạt chất từ controller truyền sang
            const currentHoatChats = !{JSON.stringify(hoatchats || [])};
            populateHoatChats(currentHoatChats);
            $('#addHoatChat').on('click', function() {
                addHoatChatInput();
            });

            $(document).on('click', '.remove-hoat-chat', function() {
                $(this).closest('.hoat-chat-item').remove();
                if ($('#listHoatChat .hoat-chat-item').length === 0) {
                    addHoatChatInput();
                }
            });
        });
        function toast(msg, bg) {
                const t = document.getElementById('toast');
                if (!t) return;
                t.textContent = msg;
                t.style.background = bg || '#333';
                t.style.opacity = '1';
                t.style.transform = 'translateX(-50%) translateY(0)';
                setTimeout(() => {
                    t.style.opacity = '0';
                    t.style.transform = 'translateX(-50%) translateY(80px)';
                }, 3000);
            }